{
  "name": "@chrissnell/chonky-ui",
  "version": "0.1.9",
  "description": "Svelte 5 component library with a monospace design system",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "svelte",
    "components",
    "ui",
    "monospace",
    "design-system"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chrissnell/chonky.git",
    "directory": "packages/chonky-ui"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "sideEffects": [
    "**/*.css",
    "./dist/index.js"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./css": "./dist/css/chonky.css",
    "./tokens": "./dist/css/tokens.css"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "svelte": "^5.0.0",
    "bits-ui": "^2.0.0",
    "@internationalized/date": "^3.8.0"
  },
  "devDependencies": {
    "svelte": "^5.0.0",
    "bits-ui": "^2.0.0",
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  },
  "scripts": {
    "build": "svelte-package -o dist",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  }
}
